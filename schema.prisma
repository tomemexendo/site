// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  phone     String  // 4 últimos dígitos do WhatsApp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Admin {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String
  createdAt DateTime @default(now())

  @@map("admins")
}

model Content {
  id        Int     @id @default(autoincrement())
  type      String  // "diet", "workout_home", "workout_gym", "challenge", "ranking"
  title     String
  description String
  link      String?
  data      String? // JSON string para dados complexos
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contents")
}
